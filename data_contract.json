{
  "contract": {
    "name": "Frostbyte Ski Supply Inventory",
    "version": "1.0.0",
    "description": "Data contract for the Frostbyte ski supply inventory analytics platform. Defines the expected schema, data quality rules, and SLAs for all models in the MARTS layer.",
    "owner": "data-engineering@frostbyte.example.com",
    "domain": "inventory-management"
  },
  "models": {
    "staging": [
      {
        "name": "stg_stores",
        "description": "Cleaned and typed store dimension from raw CSV ingest.",
        "source_table": "FROSTBYTE_DB.RAW.STORES",
        "columns": [
          {"name": "STORE_ID", "type": "VARCHAR", "description": "Unique store identifier", "tests": ["not_null", "unique"]},
          {"name": "STORE_NAME", "type": "VARCHAR", "description": "Human-readable store name", "tests": ["not_null"]},
          {"name": "CITY", "type": "VARCHAR", "description": "Resort or town where store is located", "tests": ["not_null"]},
          {"name": "STATE", "type": "VARCHAR", "description": "State or territory code", "tests": ["not_null"]},
          {"name": "COUNTRY", "type": "VARCHAR", "description": "Country code (AUS standard)", "tests": ["not_null", {"accepted_values": ["AUS", "NZL"]}]},
          {"name": "SALES_REGION", "type": "VARCHAR", "description": "Sales region based on geography", "tests": ["not_null", {"accepted_values": ["ALPINE", "SOUTHERN", "HIGHLANDS"]}]},
          {"name": "STORE_TIER", "type": "VARCHAR", "description": "Store tier classification (T1=Flagship Resort, T2=Resort Standard, T3=Village, T4=Pop-up/Seasonal)", "tests": ["not_null", {"accepted_values": ["T1", "T2", "T3", "T4"]}]},
          {"name": "OPENED_DATE", "type": "DATE", "description": "Date the store opened", "tests": ["not_null"]},
          {"name": "SQUARE_METRES", "type": "INTEGER", "description": "Store floor area in square metres", "tests": ["not_null", {"accepted_range": {"min_value": 0}}]},
          {"name": "IS_ACTIVE", "type": "BOOLEAN", "description": "Whether the store is currently operational", "tests": ["not_null"]}
        ]
      },
      {
        "name": "stg_products",
        "description": "Cleaned product dimension with pricing and supplier linkage.",
        "source_table": "FROSTBYTE_DB.RAW.PRODUCTS",
        "columns": [
          {"name": "PRODUCT_ID", "type": "VARCHAR", "description": "Unique product identifier", "tests": ["not_null", "unique"]},
          {"name": "PRODUCT_NAME", "type": "VARCHAR", "description": "Product display name", "tests": ["not_null"]},
          {"name": "CATEGORY", "type": "VARCHAR", "description": "Product category", "tests": ["not_null", {"accepted_values": ["Skis & Boards", "Boots & Bindings", "Outerwear & Apparel", "Helmets & Goggles", "Accessories", "Tuning & Maintenance"]}]},
          {"name": "CATEGORY_CODE", "type": "VARCHAR", "description": "Short code for product category", "tests": ["not_null", {"accepted_values": ["SKI", "BOO", "APP", "HEL", "ACC", "TUN"]}]},
          {"name": "UNIT_COST", "type": "NUMBER(10,2)", "description": "Cost price per unit", "tests": ["not_null", {"accepted_range": {"min_value": 0}}]},
          {"name": "UNIT_PRICE", "type": "NUMBER(10,2)", "description": "Sell price per unit", "tests": ["not_null", {"accepted_range": {"min_value": 0}}]},
          {"name": "SUPPLIER_ID", "type": "VARCHAR", "description": "FK to suppliers", "tests": ["not_null", {"relationships": {"to": "stg_suppliers", "field": "SUPPLIER_ID"}}]},
          {"name": "WEIGHT_KG", "type": "NUMBER(10,2)", "description": "Product weight in kilograms", "tests": [{"accepted_range": {"min_value": 0}}]},
          {"name": "IS_ACTIVE", "type": "BOOLEAN", "description": "Whether the product is currently sold", "tests": ["not_null"]}
        ]
      },
      {
        "name": "stg_suppliers",
        "description": "Cleaned supplier dimension.",
        "source_table": "FROSTBYTE_DB.RAW.SUPPLIERS",
        "columns": [
          {"name": "SUPPLIER_ID", "type": "VARCHAR", "description": "Unique supplier identifier", "tests": ["not_null", "unique"]},
          {"name": "SUPPLIER_NAME", "type": "VARCHAR", "description": "Supplier company name", "tests": ["not_null"]},
          {"name": "CONTACT_EMAIL", "type": "VARCHAR", "description": "Primary contact email", "tests": ["not_null"]},
          {"name": "PHONE", "type": "VARCHAR", "description": "Contact phone number"},
          {"name": "CITY", "type": "VARCHAR", "description": "Supplier city"},
          {"name": "STATE", "type": "VARCHAR", "description": "Supplier state"},
          {"name": "COUNTRY", "type": "VARCHAR", "description": "Supplier country (AUS standard)", "tests": ["not_null", {"accepted_values": ["AUS", "NZL"]}]},
          {"name": "LEAD_TIME_DAYS", "type": "INTEGER", "description": "Average lead time in days", "tests": ["not_null", {"accepted_range": {"min_value": 1}}]}
        ]
      },
      {
        "name": "stg_stock_levels",
        "description": "Cleaned stock positions per store and product.",
        "source_table": "FROSTBYTE_DB.RAW.STOCK_LEVELS",
        "columns": [
          {"name": "STOCK_LEVEL_ID", "type": "VARCHAR", "description": "Unique stock record identifier", "tests": ["not_null", "unique"]},
          {"name": "STORE_ID", "type": "VARCHAR", "description": "FK to stores", "tests": ["not_null", {"relationships": {"to": "stg_stores", "field": "STORE_ID"}}]},
          {"name": "PRODUCT_ID", "type": "VARCHAR", "description": "FK to products", "tests": ["not_null", {"relationships": {"to": "stg_products", "field": "PRODUCT_ID"}}]},
          {"name": "QUANTITY_ON_HAND", "type": "INTEGER", "description": "Current quantity in stock", "tests": ["not_null", {"accepted_range": {"min_value": 0}}]},
          {"name": "REORDER_POINT", "type": "INTEGER", "description": "Threshold to trigger reorder", "tests": ["not_null", {"accepted_range": {"min_value": 0}}]},
          {"name": "REORDER_QUANTITY", "type": "INTEGER", "description": "Standard reorder quantity", "tests": ["not_null", {"accepted_range": {"min_value": 0}}]},
          {"name": "LAST_COUNTED_DATE", "type": "DATE", "description": "Date of last physical count", "tests": ["not_null"]},
          {"name": "IS_BELOW_REORDER", "type": "BOOLEAN", "description": "Flag if quantity is below reorder point", "tests": ["not_null"]}
        ]
      },
      {
        "name": "stg_purchase_orders",
        "description": "Cleaned purchase order fact table.",
        "source_table": "FROSTBYTE_DB.RAW.PURCHASE_ORDERS",
        "columns": [
          {"name": "PO_ID", "type": "VARCHAR", "description": "Unique purchase order identifier", "tests": ["not_null", "unique"]},
          {"name": "STORE_ID", "type": "VARCHAR", "description": "FK to stores", "tests": ["not_null", {"relationships": {"to": "stg_stores", "field": "STORE_ID"}}]},
          {"name": "PRODUCT_ID", "type": "VARCHAR", "description": "FK to products", "tests": ["not_null", {"relationships": {"to": "stg_products", "field": "PRODUCT_ID"}}]},
          {"name": "SUPPLIER_ID", "type": "VARCHAR", "description": "FK to suppliers", "tests": ["not_null", {"relationships": {"to": "stg_suppliers", "field": "SUPPLIER_ID"}}]},
          {"name": "QUANTITY_ORDERED", "type": "INTEGER", "description": "Units ordered", "tests": ["not_null", {"accepted_range": {"min_value": 1}}]},
          {"name": "UNIT_COST", "type": "NUMBER(10,2)", "description": "Cost per unit at time of order", "tests": ["not_null", {"accepted_range": {"min_value": 0}}]},
          {"name": "TOTAL_COST", "type": "NUMBER(12,2)", "description": "Total order cost", "tests": ["not_null", {"accepted_range": {"min_value": 0}}]},
          {"name": "ORDER_DATE", "type": "DATE", "description": "Date order was placed", "tests": ["not_null"]},
          {"name": "EXPECTED_DELIVERY_DATE", "type": "DATE", "description": "Expected delivery date", "tests": ["not_null"]},
          {"name": "ACTUAL_DELIVERY_DATE", "type": "DATE", "description": "Actual delivery date (null if not yet delivered)"},
          {"name": "STATUS", "type": "VARCHAR", "description": "Order status", "tests": ["not_null", {"accepted_values": ["PENDING", "SHIPPED", "DELIVERED", "CANCELLED"]}]}
        ]
      }
    ],
    "marts": [
      {
        "name": "fct_inventory_health",
        "description": "Fact table combining stock positions with product and store context. One row per store-product combination with calculated health metrics.",
        "grain": "One row per STORE_ID + PRODUCT_ID",
        "columns": [
          {"name": "STORE_ID", "type": "VARCHAR", "tests": ["not_null"]},
          {"name": "STORE_NAME", "type": "VARCHAR", "tests": ["not_null"]},
          {"name": "PRODUCT_ID", "type": "VARCHAR", "tests": ["not_null"]},
          {"name": "PRODUCT_NAME", "type": "VARCHAR", "tests": ["not_null"]},
          {"name": "CATEGORY", "type": "VARCHAR", "tests": ["not_null"]},
          {"name": "CATEGORY_CODE", "type": "VARCHAR", "tests": ["not_null"]},
          {"name": "SALES_REGION", "type": "VARCHAR", "tests": ["not_null"]},
          {"name": "STORE_TIER", "type": "VARCHAR", "tests": ["not_null"]},
          {"name": "SUPPLIER_NAME", "type": "VARCHAR", "tests": ["not_null"]},
          {"name": "QUANTITY_ON_HAND", "type": "INTEGER", "tests": ["not_null"]},
          {"name": "REORDER_POINT", "type": "INTEGER", "tests": ["not_null"]},
          {"name": "IS_BELOW_REORDER", "type": "BOOLEAN", "tests": ["not_null"]},
          {"name": "DAYS_SINCE_LAST_COUNT", "type": "INTEGER", "description": "Days between last count and current date", "tests": ["not_null", {"accepted_range": {"min_value": 0}}]},
          {"name": "STOCK_VALUE", "type": "NUMBER(12,2)", "description": "QUANTITY_ON_HAND * UNIT_COST", "tests": ["not_null", {"accepted_range": {"min_value": 0}}]}
        ]
      },
      {
        "name": "fct_procurement_summary",
        "description": "Aggregated procurement metrics per supplier and product, including delivery performance.",
        "grain": "One row per SUPPLIER_ID + PRODUCT_ID",
        "columns": [
          {"name": "SUPPLIER_ID", "type": "VARCHAR", "tests": ["not_null"]},
          {"name": "SUPPLIER_NAME", "type": "VARCHAR", "tests": ["not_null"]},
          {"name": "PRODUCT_ID", "type": "VARCHAR", "tests": ["not_null"]},
          {"name": "PRODUCT_NAME", "type": "VARCHAR", "tests": ["not_null"]},
          {"name": "TOTAL_ORDERS", "type": "INTEGER", "description": "Count of purchase orders", "tests": ["not_null", {"accepted_range": {"min_value": 0}}]},
          {"name": "TOTAL_UNITS_ORDERED", "type": "INTEGER", "tests": ["not_null", {"accepted_range": {"min_value": 0}}]},
          {"name": "TOTAL_SPEND", "type": "NUMBER(14,2)", "tests": ["not_null", {"accepted_range": {"min_value": 0}}]},
          {"name": "AVG_DELIVERY_DELAY_DAYS", "type": "NUMBER(6,1)", "description": "Average days between expected and actual delivery (positive = late)"},
          {"name": "ON_TIME_DELIVERY_RATE", "type": "NUMBER(5,2)", "description": "Percentage of orders delivered on or before expected date"},
          {"name": "CANCELLED_ORDER_COUNT", "type": "INTEGER", "tests": ["not_null", {"accepted_range": {"min_value": 0}}]}
        ]
      }
    ]
  }
}
